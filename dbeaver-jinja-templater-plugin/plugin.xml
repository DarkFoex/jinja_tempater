<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
    <extension point="org.eclipse.ui.commands">
        <command
            id="com.example.dbeaver.jinja.templater.command.render"
            categoryId="org.jkiss.dbeaver.core.sql"
            name="Render Jinja Template"
            description="Render selected SQL text or current SQL editor contents using Jinja-like template variables"/>
    </extension>

    <extension point="org.eclipse.ui.handlers">
        <handler
            commandId="com.example.dbeaver.jinja.templater.command.render"
            class="com.example.dbeaver.jinja.ui.TemplateRenderCommandHandler">
            <activeWhen>
                <reference definitionId="org.jkiss.dbeaver.core.ui.sql.editor.base"/>
            </activeWhen>
        </handler>
    </extension>

    <extension point="org.eclipse.ui.commandImages">
        <image
            commandId="com.example.dbeaver.jinja.templater.command.render"
            icon="icons/jinja.png"/>
    </extension>

    <extension point="org.eclipse.ui.bindings">
        <key
            commandId="com.example.dbeaver.jinja.templater.command.render"
            contextId="org.jkiss.dbeaver.ui.editors.sql.script.focused"
            schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
            sequence="CTRL+ALT+J"/>
    </extension>

    <extension point="org.eclipse.ui.menus">
        <menuContribution allPopups="false" locationURI="menu:SQLEditorMenu?after=query">
            <command
                commandId="com.example.dbeaver.jinja.templater.command.render"
                label="Render Jinja Template"
                style="push">
                <visibleWhen checkEnabled="true"/>
            </command>
        </menuContribution>

        <menuContribution allPopups="false" locationURI="toolbar:org.jkiss.dbeaver.ui.editors.sql.toolbar.side.top?after=tools">
            <command
                commandId="com.example.dbeaver.jinja.templater.command.render"
                label="Render Jinja Template"
                style="push">
                <visibleWhen>
                    <and>
                        <reference definitionId="org.jkiss.dbeaver.core.ui.sql.editor.base"/>
                        <test property="org.jkiss.dbeaver.ui.toolbar.configuration.visible"
                              args="sqlEditor.side.top,com.example.dbeaver.jinja.templater.command.render"/>
                    </and>
                </visibleWhen>
            </command>
        </menuContribution>
    </extension>

    <extension point="org.jkiss.dbeaver.toolBarConfiguration">
        <toolBar key="sqlEditor.side.top">
            <item commandId="com.example.dbeaver.jinja.templater.command.render" defaultVisibility="true"/>
        </toolBar>
    </extension>
</plugin>
